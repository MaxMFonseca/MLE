#include "Rendering.h"

#include "../Entt.h"
#include "../UI.h"
#include "mle/core/Logger.h"
#include "mle/ui/components/Bounds.h"
#include "mle/utils/ECS.h"
#include "mle/utils/ID.h"

namespace mle::ui::system {
void Rendering::update() {
    std::ostringstream out(std::ios::binary);

    entt::snapshot{ui_.getRegistry()}.get<entt::entity>(out).get<comp::Bounds>(out);

    auto& packet = atomic_data_.producerAcquire();
    packet.id = next_packet_id_++;
    packet.blob = out.str();

    atomic_data_.producerPublish();
};

void Rendering::render() {
    if (!atomic_data_.consumerHasNew()) {
        MLE_E("No new rendering data to render. Using latest rendered image.");
        return;
    }

    const auto& latest_data = atomic_data_.consumerGetLatest();

    std::istringstream in(latest_data.blob, std::ios::binary);

    entt::snapshot_loader{render_reg_}.get<entt::entity>(in).get<comp::Bounds>(in);

    // Here you would add the actual rendering logic using render_reg_
};
}  // namespace mle::ui::system
