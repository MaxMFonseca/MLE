#pragma once

#include "mle/ui/element_renderable/Text.h"
#include "mle/window/Types.h"
namespace mle::ui::element_renderable {
class TextBox : public Text {
  public:
    TextBox(TextBox&&) = delete;
    TextBox& operator=(TextBox&&) = delete;
    TextBox(const TextBox&) = delete;
    TextBox& operator=(const TextBox&) = delete;

    explicit TextBox(ElementRef element);
    ~TextBox() override;

    void getRenderData(int layer, RenderableData& data) const override;

    void beginRangeSelection(CharPos pos);
    void endRangeSelection(CharPos pos) { selected_range_.second = pos; }

    [[nodiscard]] auto getSelectedRange() const { return selected_range_; }

    [[nodiscard]] bool isFocused() const { return focused_; }

    void setFocus(bool v);
    void focus();
    void unfocus();
    void setRenderSelection(bool v) { render_selection_ = v; }

    void backspace();
    void enter();
    void escape();

    static void registerLuaTypes();

  private:
    void renderCursor(int layer, RenderableData& data, Color color) const;
    void renderSelection(int layer, RenderableData& data, Color color) const;
    [[nodiscard]] RectInstance makeRectOnLine(int line, int from = 0, int to = max<int>()) const;

  private:
    bool render_selection_ = false;
    bool focused_ = false;
    std::pair<CharPos, CharPos> selected_range_ = {{}, {}};
    Stopwatch blink_timer_{};
    f32 blink_frequency_ = 5.F;

    ID text_listener_id_ = INVALID_ID;

    window::KeyListenerHnd lmb_out_listener_;
};
}  // namespace mle::ui::element_renderable
