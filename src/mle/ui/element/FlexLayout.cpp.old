#include "FlexLayout.h"
#include "mle/lua/Utils.h"
#include "mle/ui/UI.h"

namespace mle::ui::element {
void FlexLayout::lkhFlex(entt::entity self, const sol::object& obj) {
    MLE_ASSERT(lua::valid<sol::table>(obj));
    auto& reg = getRegistry();
    MLE_ASSERT_LOG(!reg.try_get<comp::Container>(self), "FlexLayout should not be applied to an entity that already has a Container component");

    sol::table table = obj.as<sol::table>();

    auto flex_layout = std::make_unique<FlexLayout>();

    auto& container = reg.emplace<comp::Container>(self, std::move(flex_layout));
    container.addChildren(self, table);
}

void FlexLayout::updateChildrenBounds(entt::entity self, bool force_update) const {
    auto& reg = getRegistry();
    auto& container = reg.get<comp::Container>(self);
    auto children = container.getChildren();
}
}  // namespace mle::ui::element
