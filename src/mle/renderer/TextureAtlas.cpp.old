#include "TextureAtlas.h"

#include <algorithm>

#include "mle/common/Utils.h"
#include "mle/common/math/Types.h"
#include "mle/renderer/Renderer.h"
#include "mle/renderer/Types.h"

namespace mle::renderer {
namespace {
struct PackingResult {
    std::vector<vec2u> positions;
    vec2u extent{};
};

inline bool fits(const vec2u& extent, const vec2u& rect, const vec2u& padding) {
    return extent.x >= rect.x + padding.x && extent.y >= rect.y + padding.y;
}

std::pair<bool, std::vector<vec2u>> packRects(vec2u extent, const std::vector<vec2u>& sorted_rects, vec2u padding) {
    std::vector<vec2u> ret;
    ret.reserve(sorted_rects.size());
    std::vector<Rectu> empty_spaces;
    empty_spaces.emplace_back(Rectu{{0U, 0U}, extent});

    bool all_fit = true;
    MLE_T("target_extent:{}", extent);
    for (const auto& rect : sorted_rects) {
        MLE_VT(rect);
        MLE_VT(empty_spaces.size());
        for (i32 i = static_cast<i32>(empty_spaces.size()) - 1; i >= 0; --i) {
            auto& space = empty_spaces[i];
            MLE_T("{} {}", i, space);
            if (fits(space.size, rect, padding)) {
                ret.emplace_back(space.pos.x, space.pos.y);
                MLE_T("Packed rect: {} at {}", rect, ret.back());

                Rectu bigger_remainder;
                Rectu smaller_remainder;

                if (space.size.x - rect.x > space.size.y - rect.y) {
                    bigger_remainder.pos = {space.pos.x + padding.x + rect.x, space.pos.y};
                    bigger_remainder.size = {space.size.x - rect.x - padding.x, space.size.y};
                    smaller_remainder.pos = {space.pos.x, space.pos.y + rect.y + padding.y};
                    smaller_remainder.size = {rect.x + padding.x, space.size.y - rect.y - padding.y};
                } else {
                    bigger_remainder.pos = {space.pos.x, space.pos.y + padding.y + rect.y};
                    bigger_remainder.size = {space.size.x, space.size.y - rect.y - padding.y};
                    smaller_remainder.pos = {space.pos.x + rect.x + padding.x, space.pos.y};
                    smaller_remainder.size = {space.size.x - rect.x - padding.x, rect.y + padding.y};
                }

                MLE_ASSERT(bigger_remainder.size.x + bigger_remainder.pos.x <= extent.x);
                MLE_ASSERT(bigger_remainder.size.y + bigger_remainder.pos.y <= extent.y);

                empty_spaces[i] = empty_spaces.back();
                empty_spaces.pop_back();

                if (bigger_remainder.size.x > padding.x && bigger_remainder.size.y > padding.y) {
                    empty_spaces.push_back(bigger_remainder);
                }
                if (smaller_remainder.size.x > padding.x && smaller_remainder.size.y > padding.y) {
                    empty_spaces.push_back(smaller_remainder);
                }

                break;
            }
            if (i == 0) {
                all_fit = false;
            }
        }
        if (!all_fit) {
            break;
        }
    }
    if (all_fit) {
        MLE_ASSERT_LOG(ret.size() == sorted_rects.size(), "Something is wrong with the algo.");
        return {true, ret};
    }
    return {false, ret};
};

std::vector<PackingResult> findSuitablePacking(const std::vector<vec2u>& extents, vec2u padding, vec2u max_extent) {
    if (extents.size() == 1) {
        PackingResult result;
        result.extent = extents[0];
        result.positions = {{0, 0}};
        return {result};
    }

    std::vector<PackingResult> results;
    u32 fitted = 0;

    while (fitted < extents.size()) {
        u32 max_size = 0;
        u64 area = 0;
        for (auto it = extents.begin() + fitted; it != extents.end(); ++it) {
            const auto& extent = *it;
            area += static_cast<u64>(extent.x * extent.y);
            max_size = std::max(extent.x, max_size);
            max_size = std::max(extent.y, max_size);
        }
        auto sqrt_area = static_cast<u32>(std::ceil(std::sqrt(area)));
        vec2u target_extent = {std::max(static_cast<u32>(max_size + padding.x), sqrt_area), std::max(static_cast<u32>(max_size + padding.y), sqrt_area)};
        target_extent = glm::min(target_extent, max_extent);

        auto pack_result = packRects(target_extent, {extents.begin() + fitted, extents.end()}, padding);
        while (!pack_result.first) {
            if (target_extent == max_extent) {
                MLE_T("Not all fit in one texture. Splitting.");
                break;
            }

            if (target_extent.x <= target_extent.y) {
                target_extent.x = static_cast<u32>(static_cast<f32>(target_extent.x) * 1.2);
            } else {
                target_extent.y = static_cast<u32>(static_cast<f32>(target_extent.y) * 1.2);
            }
            target_extent = glm::min(target_extent, max_extent);

            pack_result = packRects(target_extent, {extents.begin() + fitted, extents.end()}, padding);
        }
        auto& ret_result = results.emplace_back();
        ret_result.extent = target_extent;
        ret_result.positions = pack_result.second;
        fitted += pack_result.second.size();
    }

    return results;
}
};  // namespace
TextureAtlas::TextureAtlas(const GroupCreateInfo& default_group_ci) {
    addGroup(default_group_ci);
}

void TextureAtlas::addGroup(const GroupCreateInfo& ci) {
    GroupData group;
    group.atlas_padding = ci.atlas_padding;
    group.atlas_extent = ci.atlas_extent;
    group.atlas_format = ci.format;
    group.max_height_for_lazy = ci.atlas_extent.y / 8;
    if (groups_.empty()) {
        MLE_D("Craeting default group: padding: {}, extent: {}, format: {}, max_height_for_lazy: {}", ci.atlas_padding, ci.atlas_extent,
              vk::to_string(ci.format), group.max_height_for_lazy);
        if (!ci.name.empty()) {
            MLE_W("Default group name is ignored!");
        }
    } else {
        MLE_T("Creating group: {}, padding: {}, extent: {}, format: {}", ci.name, ci.atlas_padding, ci.atlas_extent, vk::to_string(ci.format));
        group.name = ci.name;
    }
    groups_.emplace_back(group);
}

TextureAtlas::GroupData& TextureAtlas::getGroup(const std::string& name) {
    if (name.empty()) {
        return groups_[0];
    }

    auto it = std::ranges::find_if(groups_, [&name](const auto& group) { return group.name == name; });
    if (it == groups_.end()) {
        MLE_THROW(ELEMENT_NOT_FOUND, "Group {} not found", name);
    }
    return *it;
}

Texture TextureAtlas::makeDefaultTexture() {
    return {.idx = images_.size(), .rect = {0.0F, 0.0F, 1.0F, 1.0F}, .aspect_ratio = 1.0};
}

Texture TextureAtlas::getTexture(const std::string& name, const std::string& group) {
    auto& group_data = getGroup(group);
    auto it = group_data.textures.find(name);
    if (it == group_data.textures.end()) {
        try {
            return addTexture(name, Image::readFile(addTexturesBasePath(name)), group);
        } catch (mle::Exception<Result::FAILED_TO_OPEN_FILE>& e) {
            MLE_E("Failed to load texture: {}", name);
            return makeDefaultTexture();
        }
    }
    return it->second;
}

usize TextureAtlas::getImageCountGroup(const std::string& group) {
    return getGroup(group).image_indices.size();
}

TextureAtlas::ImageData& TextureAtlas::createImage(vec2i extent, vk::Format format, GroupData& group_data) {
    renderer::Image::CI ci;
    ci.extent = extent;
    ci.format = format;
    ci.usage = vk::ImageUsageFlagBits::eSampled | vk::ImageUsageFlagBits::eTransferDst;
    MLE_T("Creating image, idx: {}, format: {}, extent: {}", images_.size(), vk::to_string(ci.format), ci.extent);
    group_data.image_indices.push_back(images_.size());
    image_count_changed_ = true;
    return images_.emplace_back(std::make_unique<Image>(ci));
}

TextureAtlas::ImageData& TextureAtlas::createAtlas(GroupData& group_data) {
    renderer::Image::CI ci;
    ci.extent = group_data.atlas_extent;
    ci.format = group_data.atlas_format;
    ci.usage = vk::ImageUsageFlagBits::eSampled | vk::ImageUsageFlagBits::eTransferDst;
    MLE_T("Created image for group: {}, idx: {}, format: {}, extent: {}", group_data.name, images_.size() - 1, vk::to_string(ci.format), ci.extent);
    group_data.image_indices.push_back(images_.size());
    image_count_changed_ = true;
    auto& i = images_.emplace_back(std::make_unique<Image>(ci));
    i.is_atlas = true;
    return i;
}

void TextureAtlas::addTextures(const TexturePack& texture_pack, const std::string& group) {
    for (const auto& [name, data] : texture_pack) {
        addTexture(name, data, group);
    }
}

Texture TextureAtlas::addDedicatedTexture(const std::string& name, const Image::RawData& data, GroupData& group_data) {
    MLE_ASSERT_LOG(!group_data.textures.contains(name), "Texture {} already exists in group {}", name, group_data.name);
    MLE_T("Creating dedicated texture for group: {}, extent: {}, channels: {}", group_data.name, data.extent, data.channels);

    Texture ret;
    TextureAtlas::ImageData& img = createImage(data.extent, group_data.atlas_format, group_data);
    auto cmd = beginTransferOTS();
    auto buffer = img.image->update(cmd, data.pixels.data(), data.extent);
    endTransferOTS();
    ret.idx = images_.size() - 1;
    ret.rect.pos = {0, 0};
    ret.rect.size = {1, 1};
    ret.aspect_ratio = static_cast<f32>(data.extent.x) / static_cast<f32>(data.extent.y);
    group_data.textures[name] = ret;
    MLE_D("Added dedicated texture: {}: {}", name, ret);
    return ret;
}

Texture TextureAtlas::addTextureToAtlas(const std::string& name, const Image::RawData& data, GroupData& group_data, usize idx) {
    auto& image_data = images_.at(idx);
    Texture texture;
    texture.idx = idx;
    texture.rect.pos = vec2f(image_data.cur_pos) / vec2f(image_data.image->getExtent());
    texture.rect.size = vec2f(data.extent) / vec2f(image_data.image->getExtent());
    texture.aspect_ratio = static_cast<f32>(data.extent.x) / static_cast<f32>(data.extent.y);
    group_data.textures[name] = texture;

    Buffer::CI queue_buffer_ci = {};
    queue_buffer_ci.allocation_type = Buffer::CI::AllocationType::STAGING;
    queue_buffer_ci.size = data.pixels.size();
    queue_buffer_ci.usage = vk::BufferUsageFlagBits::eTransferSrc;
    auto& queue_entry = add_queue_.emplace_back();
    queue_entry.buffer = std::make_unique<Buffer>(queue_buffer_ci);
    queue_entry.buffer->update(data.pixels.data());
    queue_entry.img_idx = idx;
    queue_entry.rect = {image_data.cur_pos, data.extent};

    auto max_x = image_data.cur_pos.x + data.extent.x;
    auto max_y = image_data.cur_pos.y + data.extent.y;

    image_data.cur_pos.x = max_x + group_data.atlas_padding.x;
    image_data.next_y = std::max(image_data.next_y, max_y + group_data.atlas_padding.y);

    MLE_D("Added texture: {}, group: {}, idx: {}, pos: {}, size: {}, aspect_ratio: {}", name, group_data.name, idx, texture.rect.pos, texture.rect.size,
          texture.aspect_ratio);
    return texture;
}

Texture TextureAtlas::addTexture(const std::string& name, const Image::RawData& data, const std::string& group) {
    auto& group_data = getGroup(group);

    if (data.extent.y > group_data.max_height_for_lazy) {
        MLE_ASSERT(data.channels == Image::getFormatChannelCount(group_data.atlas_format));
        return addDedicatedTexture(name, data, group_data);
    }

    for (auto& idx : group_data.image_indices) {
        auto& image_data = images_[idx];

        if (!image_data.is_atlas) {
            continue;
        }

        auto max_x = image_data.cur_pos.x + data.extent.x;
        auto max_y = image_data.cur_pos.y + data.extent.y;

        if (max_x <= image_data.image->getExtent().x && max_y <= image_data.image->getExtent().y) {
            return addTextureToAtlas(name, data, group_data, idx);
        }

        max_y = image_data.next_y + data.extent.y;
        if (max_y <= image_data.image->getExtent().y) {
            image_data.cur_pos = {0, image_data.next_y};
            return addTextureToAtlas(name, data, group_data, idx);
        }
    }

    createAtlas(group_data);
    return addTextureToAtlas(name, data, group_data, group_data.image_indices.back());
}

void TextureAtlas::addTexturesPacked(const TexturePack& texture_pack, vec2u padding, vec2u max_extent, const std::string& group) {
    auto& group_data = getGroup(group);

    if (max_extent == vec2u{0, 0}) {
        max_extent = {getVk().getMaxImageDimension2D(), getVk().getMaxImageDimension2D()};
    }

    for (auto it = texture_pack.begin(); it != texture_pack.end(); ++it) {
        if (it != texture_pack.begin()) {
            MLE_ASSERT(it->second.channels == texture_pack.begin()->second.channels);
        }
    }
    auto format = Image::getDefaultFormatForChannelCount(texture_pack.begin()->second.channels);

    std::vector<vec2u> extents;
    extents.reserve(texture_pack.size());
    for (const auto& [name, data] : texture_pack) {
        extents.emplace_back(data.extent.x, data.extent.y);
    }
    auto packing_result = findSuitablePacking(extents, padding, max_extent);

    auto texture_pack_it = texture_pack.begin();

    std::vector<BufferHnd> buffers;
    buffers.reserve(texture_pack.size());

    auto ots = beginTransferOTS();

    for (auto& result : packing_result) {
        auto& img = createImage(result.extent, format, group_data);
        for (auto& texture_pos : result.positions) {
            const auto& texture = texture_pack_it->second;

            buffers.emplace_back(img.image->update(ots, texture.pixels.data(), texture.extent, texture_pos));

            MLE_ASSERT_LOG(!group_data.textures.contains(texture_pack_it->first), "Texture {} already exists in group {}", texture_pack_it->first,
                           group_data.name);
            auto tex = group_data.textures[texture_pack_it->first];
            tex.idx = images_.size() - 1;
            tex.rect.pos = vec2f(texture_pos) / vec2f(result.extent);
            tex.rect.size = vec2f(texture.extent) / vec2f(result.extent);
            tex.aspect_ratio = static_cast<f32>(texture.extent.x) / static_cast<f32>(texture.extent.y);

            MLE_D("Added packed texture {}: {}", texture_pack_it->first, tex);
            texture_pack_it++;
        }
    }

    endTransferOTS();
}

Result TextureAtlas::update() {
    if (add_queue_.empty() && !image_count_changed_) {
        return Result::OK;
    }

    auto cmd = getFrameMainCommandBuffer();
    for (auto& entry : add_queue_) {
        auto& image_data = images_.at(entry.img_idx);
        image_data.image->update(cmd, entry.buffer.get(), entry.rect.size, entry.rect.pos);
        addToFrameDeleteQueue(std::move(entry.buffer));
    }
    add_queue_.clear();

    for (ImageData& i : images_) {
        i.image->transitionState(cmd, Image::State::SHADER_READ);
    }
    image_count_changed_ = false;
    return Result::IMAGE_COUNT_CHANGED;
}

WriteDescriptorSet TextureAtlas::makeWriteDescriptorSet(usize binding, vk::Sampler sampler, const Texture& texture) {
    WriteDescriptorSet ret;

    auto& i = ret.image_infos.emplace_back();
    i.imageView = images_[texture.idx].image->getDefaultView();
    i.imageLayout = vk::ImageLayout::eReadOnlyOptimal;
    i.sampler = sampler;

    ret.write.dstBinding = binding;
    ret.write.descriptorCount = 1;
    ret.write.descriptorType = vk::DescriptorType::eCombinedImageSampler;
    ret.write.setImageInfo(ret.image_infos);

    return ret;
}

WriteDescriptorSet TextureAtlas::makeWriteDescriptorSet(usize binding, vk::Sampler sampler) {
    WriteDescriptorSet ret;

    ret.image_infos.reserve(images_.size() + 1);
    for (const auto& img : images_) {
        auto& i = ret.image_infos.emplace_back();
        i.imageView = img.image->getDefaultView();
        i.imageLayout = vk::ImageLayout::eReadOnlyOptimal;
        i.sampler = sampler;
    }

    auto& default_texture = ret.image_infos.emplace_back();
    default_texture.imageView = getDefaultTextureImage()->getDefaultView();
    default_texture.imageLayout = vk::ImageLayout::eReadOnlyOptimal;
    default_texture.sampler = sampler;

    ret.write.dstBinding = binding;
    ret.write.descriptorCount = 1;
    ret.write.descriptorType = vk::DescriptorType::eCombinedImageSampler;
    ret.write.setImageInfo(ret.image_infos);

    return ret;
}

WriteDescriptorSet TextureAtlas::makeWriteDescriptorSet(usize binding, vk::Sampler sampler, const std::string& group) {
    WriteDescriptorSet ret;

    auto& group_data = getGroup(group);
    ret.image_infos.reserve(group_data.textures.size() + 1);
    for (usize idx : group_data.image_indices) {
        auto& i = ret.image_infos.emplace_back();
        i.imageView = images_[idx].image->getDefaultView();
        i.imageLayout = vk::ImageLayout::eReadOnlyOptimal;
        i.sampler = sampler;
    }

    auto& default_texture = ret.image_infos.emplace_back();
    default_texture.imageView = getDefaultTextureImage()->getDefaultView();
    default_texture.imageLayout = vk::ImageLayout::eReadOnlyOptimal;
    default_texture.sampler = sampler;

    ret.write.dstBinding = binding;
    ret.write.descriptorCount = 1;
    ret.write.descriptorType = vk::DescriptorType::eCombinedImageSampler;
    ret.write.setImageInfo(ret.image_infos);

    return ret;
}
}  // namespace mle::renderer
